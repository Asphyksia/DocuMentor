# ==============================================================================
# DocuMentor — Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the required values.
#
#   cp .env.example .env
#
# Required fields are marked with ← REQUIRED
# ==============================================================================

# ------------------------------------------------------------------------------
# RelayGPU (LLM provider)
# Get your key at: https://relay.opengpu.network
# ------------------------------------------------------------------------------

OPENAI_API_KEY=relay_sk_your_key_here        # ← REQUIRED
OPENAI_BASE_URL=https://relay.opengpu.network/v2/openai/v1
LLM_MODEL_NAME=openai/gpt-5.4

# Alternative models via OpenAI endpoint (uncomment to switch):
# LLM_MODEL_NAME=openai/gpt-5.2                  # $1.75/$14.00 per 1M tokens
# LLM_MODEL_NAME=deepseek-ai/DeepSeek-V3.1       # $0.55/$1.66 — budget option
# LLM_MODEL_NAME=moonshotai/kimi-k2.5            # $0.55/$2.95 — multilingual
# LLM_MODEL_NAME=Qwen/Qwen3.5-397B-A17B-FP8     # $0.20/$1.20 — cheapest large model
# LLM_MODEL_NAME=infercom/MiniMax-M2.5           # $0.30/$1.20 — 164K context

# Anthropic models require a different endpoint:
# OPENAI_BASE_URL=https://relay.opengpu.network/v2/anthropic/v1
# LLM_MODEL_NAME=anthropic/claude-sonnet-4-6     # $3.00/$15.00 per 1M tokens
# LLM_MODEL_NAME=anthropic/claude-opus-4-6       # $5.00/$25.00 per 1M tokens

# ------------------------------------------------------------------------------
# SurfSense core
# ------------------------------------------------------------------------------

# Generate a random secret key (run: openssl rand -base64 32)
SECRET_KEY=replace_me_with_random_string     # ← REQUIRED

# Document parsing (DOCLING runs locally, no external API needed)
ETL_SERVICE=DOCLING

# Embedding model (local, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Auth type: LOCAL (email/password)
AUTH_TYPE=LOCAL

# ------------------------------------------------------------------------------
# MCP Wrapper
# ------------------------------------------------------------------------------

SURFSENSE_BASE_URL=http://localhost:8929
SURFSENSE_EMAIL=admin@documenter.local       # ← set this to your SurfSense account email
SURFSENSE_PASSWORD=changeme                  # ← REQUIRED: set a strong password
MCP_PORT=8000

# ------------------------------------------------------------------------------
# Dashboard (Next.js)
# ------------------------------------------------------------------------------

NEXT_PUBLIC_MCP_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_SPACE_ID=1

# ------------------------------------------------------------------------------
# Ports (change only if something conflicts on your machine)
# ------------------------------------------------------------------------------

# BACKEND_PORT=8929
# FRONTEND_PORT=3929
# ELECTRIC_PORT=5929

# ------------------------------------------------------------------------------
# Optional: custom domain / reverse proxy
# Only needed if serving DocuMentor on a real domain.
# ------------------------------------------------------------------------------

# NEXT_FRONTEND_URL=https://documenter.yourdomain.com
# NEXT_PUBLIC_FASTAPI_BACKEND_URL=https://api.yourdomain.com
