FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl git build-essential && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Bridge dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Hermes Agent dependencies (core only — no TTS, no browser, no modal)
# These are needed for AIAgent import to work.
RUN pip install --no-cache-dir \
    openai \
    "anthropic>=0.39.0" \
    fire \
    rich \
    tenacity \
    pyyaml \
    requests \
    jinja2 \
    prompt_toolkit \
    "litellm>=1.75.5,<1.82.7" \
    typer \
    platformdirs \
    "PyJWT[crypto]" \
    "mcp[cli]>=1.0.0"

COPY bridge.py .

EXPOSE 8001
